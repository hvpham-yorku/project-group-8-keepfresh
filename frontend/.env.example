# Used when running: npm run dev (not by docker-compose; see project root .env for Docker).
# NEXT_PUBLIC_* is inlined at dev server start - restart after changes.

# LAN IP or hostname only (e.g. 192.168.1.10). QR codes and API_BASE use http://<host>:3000 and :8000.
NEXT_PUBLIC_DEV_HOST=

# Optional full URL overrides (local or Vercel). No trailing slashes.
# NEXT_PUBLIC_API_URL=http://192.168.1.10:8000
# NEXT_PUBLIC_APP_URL=http://192.168.1.10:3000
# Vercel production example:
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
