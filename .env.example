# Copy to .env and fill in. Do not commit .env.

# --- MongoDB ---
# Prefer a single full URI (e.g. Atlas), or leave unset and use MONGODB_HOST + MONGODB_PORT (e.g. Render private Mongo).
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/keepfresh?retryWrites=true&w=majority
# MONGODB_HOST=
# MONGODB_PORT=27017

# --- OpenAI (receipt OCR + recommendations) ---
# Get a key: https://platform.openai.com/api-keys
OPEN_API_KEY=

# --- CORS (comma-separated origins). Add http://<your-LAN-ip>:3000 for phone testing.
CORS_ORIGINS=http://localhost:3000
# Optional: LAN IP or hostname only (no http://). Backend also allows http://<DEV_HOST>:3000
DEV_HOST=

# --- JWT (optional locally; required strong secret in production) ---
JWT_SECRET=

# --- Email notifications (optional). If any of HOST/USER/PASS is missing, only server logs run.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Frontend (Docker Compose build args; must rebuild frontend after changes) ---
# LAN IP or hostname only, e.g. 192.168.1.10 - used for QR codes and API base URL in the bundle.
NEXT_PUBLIC_DEV_HOST=
# Optional overrides:
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_APP_URL=
